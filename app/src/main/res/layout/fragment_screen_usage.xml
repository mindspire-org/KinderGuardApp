<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/kg_surface"
    tools:context=".ui.parent.fragments.ScreenUsageFragment">

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvUsage"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingTop="8dp"
        android:paddingBottom="16dp"
        tools:listitem="@layout/item_usage" />

    <TextView
        android:id="@+id/tvEmptyState"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"
        android:gravity="center"
        android:text="No usage data yet for today."
        android:textColor="@color/kg_text_gray"
        android:textSize="15sp"
        android:visibility="gone"
        tools:visibility="visible" />

</FrameLayout>
