<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/kg_white"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp">

    <FrameLayout
        android:layout_width="140dp"
        android:layout_height="140dp"
        android:background="@drawable/bg_avatar_danger">

        <ImageView
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_gravity="center"
            android:contentDescription="@null"
            android:tint="@color/kg_white"
            android:src="@drawable/ic_blocked" />
    </FrameLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="28dp"
        android:gravity="center"
        android:text="@string/blocked_app_title"
        android:textColor="@color/kg_navy"
        android:textSize="22sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:gravity="center"
        android:text="@string/blocked_app_desc"
        android:textColor="@color/kg_text_gray"
        android:textSize="15sp" />

    <TextView
        android:id="@+id/tvBlockedAppName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:background="@drawable/bg_chip_danger"
        android:gravity="center"
        android:paddingStart="18dp"
        android:paddingEnd="18dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:textColor="@color/kg_danger"
        android:textSize="16sp"
        android:textStyle="bold"
        tools:text="TikTok" />

    <Button
        android:id="@+id/btnGoBack"
        style="@style/KgButton.Primary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="@string/go_back" />

</LinearLayout>
