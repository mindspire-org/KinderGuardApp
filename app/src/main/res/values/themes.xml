<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.KinderGuard" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/kg_primary_blue</item>
        <item name="colorPrimaryDark">@color/kg_primary_blue_dark</item>
        <item name="colorSecondary">@color/kg_teal</item>
        <item name="android:statusBarColor">@color/kg_white</item>
        <item name="android:windowLightStatusBar" tools:targetApi="23">true</item>
        <item name="android:windowBackground">@color/kg_white</item>
    </style>

    <style name="Theme.KinderGuard.Blocked" parent="Theme.KinderGuard">
        <item name="android:windowIsTranslucent">false</item>
    </style>

    <style name="KgButton.Primary" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/kg_primary_blue</item>
        <item name="cornerRadius">28dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">16sp</item>
        <item name="android:padding">14dp</item>
    </style>

    <style name="KgButton.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="cornerRadius">28dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">16sp</item>
    </style>

    <style name="KgTextField" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">28dp</item>
        <item name="boxCornerRadiusTopEnd">28dp</item>
        <item name="boxCornerRadiusBottomStart">28dp</item>
        <item name="boxCornerRadiusBottomEnd">28dp</item>
        <item name="boxStrokeColor">@color/kg_field_bg</item>
    </style>
</resources>
